{
  "name": "html2pdf-windows",
  "version": "1.0.0",
  "main": "dist-electron/main/index.js",
  "description": "A lightweight Windows tool for converting HTML to high-quality PDF with accurate CSS layout.",
  "author": "bingqianliu2017",
  "repository": "https://github.com/bingqianliu2017/html2pdf-windows",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js",
    "build": "node node_modules/typescript/bin/tsc && node node_modules/vite/bin/vite.js build && electron-builder",
    "postbuild": "del release\\builder-*.yml release\\builder-*.yaml release\\*.blockmap release\\latest.yml 2>nul",
    "preview": "node node_modules/vite/bin/vite.js preview"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.4.2",
    "vite": "^6.3.6",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.html2pdf.app",
    "productName": "html2pdf-windows",
    "directories": {
      "output": "release"
    }
  }
}
